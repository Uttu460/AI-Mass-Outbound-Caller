LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-2.0-flash-live-001
GEMINI_TTS_VOICE=Aoede
USE_GEMINI_REALTIME=true
SYSTEM_PROMPT=
ENABLED_TOOLS=[]

TWILIO_TRUNK_SID=ST_your_twilio_or_livekit_trunk_sid
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
DEFAULT_TRANSFER_NUMBER=

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- Watchdog tunables (optional) ---
CALL_SILENCE_TIMEOUT=15
AGENT_FIRST_SPEECH_TIMEOUT=30

S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_REGION=ap-northeast-1
S3_BUCKET=call-recordings

DEEPGRAM_API_KEY=
